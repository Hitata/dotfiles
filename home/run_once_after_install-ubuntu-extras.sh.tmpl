#!/usr/bin/env bash
# One-time bootstrap for Ubuntu-only installers that don't fit apt/snap.
# Each step is idempotent via `command -v` guards.
# Re-runs only when this script's content changes (run_once + chezmoi state).
set -euo pipefail

if ! command -v apt-get >/dev/null 2>&1; then
    exit 0  # Not Debian/Ubuntu
fi

step() { echo ""; echo "── $* ──"; }

# ── fnm (node version manager) ───────────────────────────────
step "fnm"
if command -v fnm >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsSL https://fnm.vercel.app/install | bash
fi

# ── pnpm ─────────────────────────────────────────────────────
step "pnpm"
if command -v pnpm >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsSL https://get.pnpm.io/install.sh | sh -
fi

# ── Claude Code ──────────────────────────────────────────────
step "Claude Code"
if command -v claude >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsSL https://claude.ai/install.sh | bash
fi

# ── Brave browser ────────────────────────────────────────────
step "Brave"
if command -v brave-browser >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsS https://dl.brave.com/install.sh | sh
fi

# ── Google Chrome (official .deb — postinst wires up apt repo) ──
step "Google Chrome"
if command -v google-chrome >/dev/null 2>&1 || command -v google-chrome-stable >/dev/null 2>&1; then
    echo "  · already installed"
elif [[ "$(dpkg --print-architecture)" != "amd64" ]]; then
    echo "  · skipping — Chrome for Linux is amd64 only"
else
    tmpdeb=$(mktemp --suffix=.deb)
    curl -fsSL -o "$tmpdeb" https://dl.google.com/linux/direct/google-chrome-stable_current_amd64.deb
    sudo apt-get install -y "$tmpdeb"
    rm -f "$tmpdeb"
fi

# ── cloudflared (APT via Cloudflare repo) ────────────────────
step "cloudflared"
if command -v cloudflared >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsSL https://pkg.cloudflare.com/cloudflare-main.gpg \
        | sudo tee /usr/share/keyrings/cloudflare-main.gpg > /dev/null
    echo "deb [signed-by=/usr/share/keyrings/cloudflare-main.gpg] https://pkg.cloudflare.com/cloudflared any main" \
        | sudo tee /etc/apt/sources.list.d/cloudflared.list > /dev/null
    sudo apt-get update -qq
    sudo apt-get install -y cloudflared
fi

# ── Docker Engine (upstream APT repo — not snap, not docker.io) ──
step "Docker"
if command -v docker >/dev/null 2>&1; then
    echo "  · already installed"
else
    sudo install -m 0755 -d /etc/apt/keyrings
    curl -fsSL https://download.docker.com/linux/ubuntu/gpg \
        | sudo tee /etc/apt/keyrings/docker.asc > /dev/null
    sudo chmod a+r /etc/apt/keyrings/docker.asc
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/etc/apt/keyrings/docker.asc] https://download.docker.com/linux/ubuntu $(. /etc/os-release && echo "$VERSION_CODENAME") stable" \
        | sudo tee /etc/apt/sources.list.d/docker.list > /dev/null
    sudo apt-get update -qq
    sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
fi

# Add user to docker group (takes effect on next login) — idempotent
if ! id -nG "$USER" | grep -qw docker; then
    echo "  + adding $USER to docker group (re-login required)"
    sudo usermod -aG docker "$USER"
fi

# ── Tailscale (APT via Tailscale repo) ───────────────────────
step "Tailscale"
if command -v tailscale >/dev/null 2>&1; then
    echo "  · already installed"
else
    curl -fsSL https://tailscale.com/install.sh | sh
    echo "  → log in with: sudo tailscale up --hostname=<this-machine>"
fi

# ── Mullvad VPN (APT via Mullvad repo) ───────────────────────
step "Mullvad VPN"
if command -v mullvad >/dev/null 2>&1; then
    echo "  · already installed"
else
    sudo curl -fsSLo /usr/share/keyrings/mullvad-keyring.asc \
        https://repository.mullvad.net/deb/mullvad-keyring.asc
    echo "deb [signed-by=/usr/share/keyrings/mullvad-keyring.asc arch=$(dpkg --print-architecture)] https://repository.mullvad.net/deb/stable $(lsb_release -cs) main" \
        | sudo tee /etc/apt/sources.list.d/mullvad.list > /dev/null
    sudo apt-get update -qq
    sudo apt-get install -y mullvad-vpn
    echo "  → log in with: mullvad account login <account-number>"
fi

# ── tmux boot persistence (linger + reload tmux for continuum-boot) ──
# continuum writes ~/.config/systemd/user/tmux.service on tmux start when
# @continuum-boot is 'on'. Linger lets that user unit run without an active
# login — required for a headless home server to auto-restore tmux on reboot.
step "tmux boot persistence"
if loginctl show-user "$USER" 2>/dev/null | grep -q "Linger=yes"; then
    echo "  · linger already enabled"
else
    echo "  + enabling linger for $USER (sudo)"
    sudo loginctl enable-linger "$USER"
fi
echo "  → after first tmux session, verify: systemctl --user status tmux.service"

echo ""
echo "==> Ubuntu extras bootstrap complete"
