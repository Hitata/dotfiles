#!/usr/bin/env bash
# GNOME gsettings tweaks for Ubuntu.
# Re-runs when this script changes. Idempotent — `gsettings set` is safe to re-apply.
set -euo pipefail

if [[ "$(uname)" != "Linux" ]] || ! command -v gsettings &>/dev/null; then
    exit 0
fi

step() { echo ""; echo "── $* ──"; }

# ── Display / text ───────────────────────────────────────────
# 1.5× text scaling compensates for 4K on 27" without forcing
# Wayland-only fractional display scaling.
step "Display / text"
gsettings set org.gnome.desktop.interface text-scaling-factor 1.5

# ── Vietnamese input (IBus Bamboo) ───────────────────────────
# Enables US + Bamboo as input sources and per-window switching,
# so terminals stay English while chat/docs apps remember Vietnamese.
if dpkg -s ibus-bamboo &>/dev/null; then
    step "Input sources (IBus Bamboo)"
    gsettings set org.gnome.desktop.input-sources sources "[('xkb','us'),('ibus','Bamboo')]"
    gsettings set org.gnome.desktop.input-sources per-window true
    command -v ibus &>/dev/null && ibus restart &>/dev/null || true
fi

echo ""
echo "==> GNOME settings applied"
