# Appearance — auto-switches with macOS light/dark mode (live, no restart)
theme = light:catppuccin-latte-darktext,dark:Snazzy
font-family = "Hack Nerd Font Mono"
font-size = 14
adjust-cell-height = 10%

# Transparent-over-browser — tweak opacity to taste (0.0–1.0)
# NOTE: no explicit `background =` here — let the theme set it so light mode
# isn't forced dark. Opacity/blur still apply over whichever theme is active.
# Opacity is GLOBAL (Ghostty can't set it per light/dark theme). Raised from
# 0.69 → 0.92 so the light theme stays legible instead of washing out.
background-opacity = 0.92
background-blur = 0
bold-is-bright = true
minimum-contrast = 2.5
macos-titlebar-style = transparent

# Window
window-padding-x = 10
window-padding-y = 10
window-padding-balance = true
window-save-state = always
macos-option-as-alt = true

# Behavior
copy-on-select = clipboard
mouse-hide-while-typing = true
confirm-close-surface = false
shell-integration = detect
shell-integration-features = cursor,sudo,title

# Cursor
cursor-style = block
cursor-style-blink = false

# Clipboard — let tmux OSC 52 through to the system clipboard (local + SSH)
clipboard-read = allow
clipboard-write = allow

# Quick drop-down terminal (Cmd+`)
keybind = global:cmd+grave_accent=toggle_quick_terminal

# Ghostty opens a plain shell in $HOME. Run `tmuxgo` to attach the persistent
# 'main' tmux session (and restore its layout if empty).
